# Execution mode: "paper" (default) or "live"
EXECUTION_MODE=paper

# Telegram (required in live mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SQLite database path
DB_PATH=bot.db

# Symbols to monitor (comma-separated)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Risk limits
MIN_NET_EDGE_BPS=3          # minimum net funding edge to propose (in basis points)
TRADE_NOTIONAL_USDT=100     # per-trade size in USDT
MAX_GLOBAL_NOTIONAL_USDT=1000

# Exchange API keys (trade-only, NO withdrawal permissions)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
HYPERLIQUID_KEY=
